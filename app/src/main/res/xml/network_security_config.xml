<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Rotato talks to a self-hosted animebacks server that may be on http://.
        Cleartext is intentionally permitted — this app has no cloud backend.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
